# Expo reads EXPO_PUBLIC_* vars into the client bundle. These two are the
# only values the mobile app needs. Both are SAFE to ship: the anon key is
# public by design and all access is enforced by Row Level Security.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
