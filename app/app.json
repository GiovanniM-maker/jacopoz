{
  "expo": {
    "name": "jacopoz",
    "slug": "jacopoz",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "jacopoz",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B0F",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.jacopoz.beta"
    },
    "android": {
      "package": "app.jacopoz.beta"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
