# =====================================================================
# jacopoz — root environment example
# Copy to .env and fill in. NEVER commit real values.
# The mobile app reads its own app/.env (see app/.env.example).
# =====================================================================

# --- Supabase project ---------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key is used ONLY by Edge Functions / server tooling. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# --- External book metadata providers (server side only) ----------------
# Google Books works without a key for low volume; a key raises quota.
GOOGLE_BOOKS_API_KEY=
# Open Library needs no key. Send a descriptive User-Agent per their policy.
OPEN_LIBRARY_USER_AGENT=jacopoz/0.1 (contact@yourdomain.example)
